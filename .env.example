# ── LLM Provider ──────────────────────────────────────────────────────────────
# Provider: openai | anthropic
LLM_PROVIDER=openai

# API key (also reads OPENAI_API_KEY / ANTHROPIC_API_KEY as fallback)
LLM_API_KEY=sk-...

# Base URL — change for OpenAI-compatible endpoints (e.g. local vLLM)
LLM_BASE_URL=https://api.openai.com

# Model name
LLM_MODEL=gpt-4o-mini

# ── Embedding Provider ────────────────────────────────────────────────────────
# Provider: openai | bge-m3 | hashing
EMBEDDING_PROVIDER=openai

# API key for openai embeddings (leave blank for bge-m3/hashing)
EMBEDDING_API_KEY=sk-...

EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_MODEL=text-embedding-3-small

# ── BGE-M3 local model (only used when EMBEDDING_PROVIDER=bge-m3) ─────────────
# Defaults to "BAAI/bge-m3" which resolves from ~/.cache/huggingface automatically
# BGE_M3_MODEL=BAAI/bge-m3
# BGE_M3_DEVICE=cpu
# BGE_M3_USE_FP16=false
# BGE_M3_BATCH_SIZE=12

# ── Storage ───────────────────────────────────────────────────────────────────
SKILL_BANK_PATH=./SkillBank

# ── Session ───────────────────────────────────────────────────────────────────
USER_ID=u1

# Scope: user | library | all
SKILL_SCOPE=user

# ── Extractor Mode ────────────────────────────────────────────────────────────
# learner : CS student mode — extracts algorithm patterns + generates runnable scripts
# default : Preference mode — extracts user-specific workflows and personal preferences
EXTRACTOR_MODE=learner

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Minimum similarity score to inject a skill (0.0 - 1.0)
MIN_SCORE=0.4

# Number of skills to retrieve per turn
TOP_K=3

# Query rewriting: always | auto | never
REWRITE_MODE=always

# ── Extraction ────────────────────────────────────────────────────────────────
# Extract mode: auto | always | never
EXTRACT_MODE=auto

# ── Chat ──────────────────────────────────────────────────────────────────────
# Note: even when AGENT_BACKEND is `codex` or `claude-code`, EvoSkill still uses
# the main `LLM_*` config for query rewriting, skill selection, reviewing, and
# usage judging.
ASSISTANT_TEMPERATURE=0.7
USAGE_TRACKING=true

# ── Docker Agent Backend (optional) ───────────────────────────────────────────
# Backend: llm | claude-code | codex
AGENT_BACKEND=llm

# Recommended prebuilt-image path for Docker agent backends:
# AGENT_USE_PREBUILT_IMAGE=true
# AGENT_DOCKER_IMAGE=evoskill-agents:latest
# AGENT_DOCKER_CONTEXT=default

# Optional explicit agent API/model settings. If empty, backend-specific env vars
# are used automatically (e.g. ANTHROPIC_* for claude-code, OPENAI_* for codex).
AGENT_MODEL=
AGENT_API_KEY=
AGENT_BASE_URL=
AGENT_VERSION=

# Backend-specific agent credentials/config:
# Codex / OpenAI CLI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Claude Code CLI
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# Claude Code only
AGENT_MAX_THINKING_TOKENS=0

# Docker runtime settings
AGENT_WORKSPACE_DIR=.
AGENT_LOGS_DIR=./trail
AGENT_USE_PREBUILT_IMAGE=false
AGENT_KEEP_CONTAINER=false
AGENT_DOCKER_IMAGE=
AGENT_DOCKER_CONTEXT=
AGENT_DOCKER_MEMORY=2G
AGENT_DOCKER_CPUS=2
AGENT_DOCKER_NETWORK=bridge
